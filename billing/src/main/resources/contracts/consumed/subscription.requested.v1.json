{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assine.local/contracts/consumed/subscription.requested.v1.json",
  "title": "subscription.requested payload (v1) - consumed by billing",
  "type": "object",
  "required": ["subscriptionId", "userId", "userEmail", "planId", "status", "planSnapshot"],
  "additionalProperties": true,
  "properties": {
    "subscriptionId": { "type": "string", "format": "uuid" },
    "userId":         { "type": "string", "format": "uuid" },
    "userEmail":      { "type": "string", "format": "email" },
    "userName":       { "type": "string" },
    "planId":         { "type": "string", "format": "uuid" },
    "status":         { "enum": ["PENDING_PAYMENT", "TRIAL"] },
    "planSnapshot": {
      "type": "object",
      "required": ["price", "currency", "billingInterval", "trialDays"],
      "additionalProperties": true,
      "properties": {
        "price":           { "type": "number", "minimum": 0 },
        "currency":        { "type": "string", "minLength": 3, "maxLength": 3 },
        "billingInterval": { "enum": ["MONTHLY", "YEARLY"] },
        "trialDays":       { "type": "integer", "minimum": 0 },
        "stripePriceId":   { "type": ["string", "null"] }
      }
    },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
