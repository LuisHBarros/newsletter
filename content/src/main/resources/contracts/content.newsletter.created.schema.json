{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assine.com/contracts/content.newsletter.created.v1.json",
  "title": "content.newsletter.created",
  "type": "object",
  "required": ["eventId", "eventType", "schemaVersion", "aggregateType", "aggregateId", "occurredAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "content.newsletter.created" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "aggregateType": { "const": "Newsletter" },
    "aggregateId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "required": ["newsletterId", "slug", "name", "planIds"],
      "properties": {
        "newsletterId": { "type": "string", "format": "uuid" },
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "planIds": { "type": "array", "items": { "type": "string", "format": "uuid" } }
      }
    }
  }
}
