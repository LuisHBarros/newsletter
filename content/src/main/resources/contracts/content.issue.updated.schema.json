{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assine.com/contracts/content.issue.updated.v1.json",
  "title": "content.issue.updated",
  "type": "object",
  "required": ["eventId", "eventType", "schemaVersion", "aggregateType", "aggregateId", "occurredAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "content.issue.updated" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "aggregateType": { "const": "Issue" },
    "aggregateId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "required": ["newsletterId", "issueId", "version"],
      "properties": {
        "newsletterId": { "type": "string", "format": "uuid" },
        "issueId": { "type": "string", "format": "uuid" },
        "version": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
