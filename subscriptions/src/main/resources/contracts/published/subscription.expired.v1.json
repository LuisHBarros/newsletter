{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assine.com/schemas/events/subscription.expired.v1.json",
  "title": "subscription.expired",
  "description": "Emitted when a subscription's current period ends without renewal and the subscription transitions to EXPIRED state.",
  "type": "object",
  "required": ["subscriptionId", "userId", "planId", "expiredAt"],
  "properties": {
    "subscriptionId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the expired subscription"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the subscriber"
    },
    "planId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the plan"
    },
    "expiredAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the expiration occurred"
    },
    "reason": {
      "type": "string",
      "description": "Optional reason for expiration",
      "enum": ["period_ended", "payment_failed"]
    }
  },
  "additionalProperties": false
}
